name: Build Debug APK

# Trigger on push to main/master, on PR, or manually via the Actions tab.
on:
  push:
    branches: ["main", "master"]
  pull_request:
    branches: ["main", "master"]
  workflow_dispatch:

jobs:
  build:
    name: Build app-debug.apk
    runs-on: ubuntu-latest
    timeout-minutes: 30

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17 (Temurin)
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'

      - name: Set up Android SDK (cmdline-tools, platform 34, build-tools 34.0.0)
        uses: android-actions/setup-android@v3
        with:
          packages: 'platform-tools platforms;android-34 build-tools;34.0.0'

      - name: Set up Gradle 8.7
        uses: gradle/actions/setup-gradle@v4
        with:
          gradle-version: '8.7'

      - name: Cache Gradle caches & wrapper
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: ${{ runner.os }}-gradle-${{ hashFiles('**/*.gradle*', '**/gradle-wrapper.properties', '**/libs.versions.toml') }}
          restore-keys: |
            ${{ runner.os }}-gradle-

      - name: Generate Gradle wrapper (gradle-wrapper.jar) if missing
        # The project ships only the wrapper properties; the wrapper jar is
        # generated here so the build can use ./gradlew on subsequent runs.
        run: |
          if [ ! -f ./gradlew ] || [ ! -f ./gradle/wrapper/gradle-wrapper.jar ]; then
            gradle wrapper --gradle-version 8.7
          fi
          chmod +x ./gradlew

      - name: Show toolchain versions
        run: |
          echo "Java:"   && java -version
          echo "Gradle:" && ./gradlew --version
          echo "SDK:"    && echo "$ANDROID_SDK_ROOT" && ls "$ANDROID_SDK_ROOT" || true

      - name: Build debug APK
        run: ./gradlew :app:assembleDebug --no-daemon --stacktrace

      - name: List build outputs
        if: always()
        run: |
          echo "--- APKs ---"
          find app/build/outputs/apk -type f -name "*.apk" -print -exec ls -lh {} \; || true

      - name: Upload app-debug.apk as workflow artifact
        uses: actions/upload-artifact@v4
        with:
          name: app-debug-apk
          path: app/build/outputs/apk/debug/app-debug.apk
          if-no-files-found: error
          retention-days: 30
          compression-level: 0
